{
  "info": {
    "name": "Booking Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/register", "host": ["http://localhost:3000"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/auth/login", "host": ["http://localhost:3000"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Haircut\",\n  \"description\": \"Professional haircut\",\n  \"duration\": 60,\n  \"price\": 25.5,\n  \"isActive\": true\n}"
            },
            "url": { "raw": "http://localhost:3000/api/services", "host": ["http://localhost:3000"], "path": ["api", "services"] }
          }
        },
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:3000/api/services", "host": ["http://localhost:3000"], "path": ["api", "services"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Jane Doe\",\n  \"customerEmail\": \"jane@example.com\",\n  \"customerPhone\": \"+94771234567\",\n  \"serviceId\": 1,\n  \"bookingDate\": \"2026-08-25\",\n  \"bookingTime\": \"14:30\",\n  \"notes\": \"Please call before arriving\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/bookings", "host": ["http://localhost:3000"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "Get Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:3000/api/bookings", "host": ["http://localhost:3000"], "path": ["api", "bookings"] }
          }
        }
      ]
    }
  ]
}
